# ============================================================================
# Vedge Patient (Flutter) — Configuration
# ============================================================================
# Flutter doesn't read .env files at runtime. These values are passed via
# --dart-define flags when building or running:
#
#   flutter run --dart-define=API_BASE_URL=http://localhost:8050
#   flutter build apk --dart-define=API_BASE_URL=https://api.vedge.health
#
# The defaults below are what the app uses when no --dart-define is provided
# (see lib/core/config.dart).
# ============================================================================

# Backend API base URL (default: http://localhost:8050)
# For Android emulator use http://10.0.2.2:8050 (maps to host localhost)
API_BASE_URL=http://localhost:8050
